"""Type stubs for thorvg_cython.thorvg — Cython bindings for ThorVG."""

from __future__ import annotations

from enum import IntEnum
from typing import Sequence, overload

# ═══════════════════════════════════════════════════════════════════
#  Enumerations
# ═══════════════════════════════════════════════════════════════════

class Result(IntEnum):
    SUCCESS: int
    INVALID_ARGUMENT: int
    INSUFFICIENT_CONDITION: int
    FAILED_ALLOCATION: int
    MEMORY_CORRUPTION: int
    NOT_SUPPORTED: int
    UNKNOWN: int

class Colorspace(IntEnum):
    ABGR8888: int
    ARGB8888: int
    ABGR8888S: int
    ARGB8888S: int
    UNKNOWN: int

class EngineOption(IntEnum):
    NONE: int
    DEFAULT: int
    SMART_RENDER: int

class MaskMethod(IntEnum):
    NONE: int
    ALPHA: int
    INVERSE_ALPHA: int
    LUMA: int
    INVERSE_LUMA: int
    ADD: int
    SUBTRACT: int
    INTERSECT: int
    DIFFERENCE: int
    LIGHTEN: int
    DARKEN: int

class BlendMethod(IntEnum):
    NORMAL: int
    MULTIPLY: int
    SCREEN: int
    OVERLAY: int
    DARKEN: int
    LIGHTEN: int
    COLORDODGE: int
    COLORBURN: int
    HARDLIGHT: int
    SOFTLIGHT: int
    DIFFERENCE: int
    EXCLUSION: int
    HUE: int
    SATURATION: int
    COLOR: int
    LUMINOSITY: int
    ADD: int
    COMPOSITION: int

class TvgType(IntEnum):
    UNDEF: int
    SHAPE: int
    SCENE: int
    PICTURE: int
    TEXT: int
    LINEAR_GRAD: int
    RADIAL_GRAD: int

class PathCommand(IntEnum):
    CLOSE: int
    MOVE_TO: int
    LINE_TO: int
    CUBIC_TO: int

class StrokeCap(IntEnum):
    BUTT: int
    ROUND: int
    SQUARE: int

class StrokeJoin(IntEnum):
    MITER: int
    ROUND: int
    BEVEL: int

class StrokeFill(IntEnum):
    PAD: int
    REFLECT: int
    REPEAT: int

class FillRule(IntEnum):
    NON_ZERO: int
    EVEN_ODD: int

class TextWrap(IntEnum):
    NONE: int
    CHARACTER: int
    WORD: int
    SMART: int
    ELLIPSIS: int
    HYPHENATION: int

class FilterMethod(IntEnum):
    BILINEAR: int
    NEAREST: int

# ═══════════════════════════════════════════════════════════════════
#  Data classes
# ═══════════════════════════════════════════════════════════════════

class ColorStop:
    __slots__: tuple[str, ...]
    offset: float
    r: int
    g: int
    b: int
    a: int
    def __init__(self, offset: float, r: int, g: int, b: int, a: int = 255) -> None: ...

class Point:
    __slots__: tuple[str, ...]
    x: float
    y: float
    def __init__(self, x: float, y: float) -> None: ...

class Matrix:
    __slots__: tuple[str, ...]
    e11: float
    e12: float
    e13: float
    e21: float
    e22: float
    e23: float
    e31: float
    e32: float
    e33: float
    def __init__(
        self,
        e11: float = 1, e12: float = 0, e13: float = 0,
        e21: float = 0, e22: float = 1, e23: float = 0,
        e31: float = 0, e32: float = 0, e33: float = 1,
    ) -> None: ...

class TextMetrics:
    __slots__: tuple[str, ...]
    ascent: float
    descent: float
    linegap: float
    advance: float
    def __init__(
        self,
        ascent: float = 0, descent: float = 0,
        linegap: float = 0, advance: float = 0,
    ) -> None: ...

# ═══════════════════════════════════════════════════════════════════
#  PixelBuffer
# ═══════════════════════════════════════════════════════════════════

class PixelBuffer:
    """Heap-allocated RGBA pixel buffer implementing PEP 3118 buffer protocol."""
    def __init__(self, w: int, h: int, cs: int = 0, stride: int = 0) -> None: ...
    def __getbuffer__(self, buffer: object, flags: int) -> None: ...
    def __releasebuffer__(self, buffer: object) -> None: ...
    def __len__(self) -> int: ...
    def __repr__(self) -> str: ...
    @property
    def width(self) -> int: ...
    @property
    def height(self) -> int: ...
    @property
    def stride(self) -> int: ...
    @property
    def colorspace(self) -> Colorspace: ...
    @property
    def nbytes(self) -> int: ...
    @property
    def ptr(self) -> int: ...
    def clear(self) -> None: ...

